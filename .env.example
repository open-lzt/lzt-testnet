LZT_TESTNET_HOST=127.0.0.1
LZT_TESTNET_PORT=8765
LZT_TESTNET_LOG_LEVEL=INFO

# Gauntlet chaos harness (all OFF by default — the server stays a clean mock).
# Intensity: off | calm | flaky | hostile | lzt_friday
LZT_TESTNET_CHAOS_MODE=off
# Determinism seed — same seed reproduces the exact fault + data sequence.
LZT_TESTNET_CHAOS_SEED=0
# A named scenario from scenarios/<name>.yaml (overrides MODE/SEED when set).
LZT_TESTNET_CHAOS_SCENARIO=
